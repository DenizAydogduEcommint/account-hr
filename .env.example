# account-hr environment variables.
# Copy to `.env` (which is gitignored — never commit real secrets):
#   cp .env.example .env

# --- PostgreSQL (used by the `db` service in docker-compose) ---
POSTGRES_DB=accounthr
POSTGRES_USER=accounthr
POSTGRES_PASSWORD=accounthr

# --- Spring Boot datasource (used by the `api` service) ---
# In Docker these point at the `db` service host; locally use localhost.
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/accounthr
SPRING_DATASOURCE_USERNAME=accounthr
SPRING_DATASOURCE_PASSWORD=accounthr

# Active Spring profile: local | docker | staging | prod
SPRING_PROFILES_ACTIVE=docker

# --- Fatura dosya depolama kökü (E1-04) ---
# Faturaların yazıldığı kök dizin. REPO DIŞINDADIR ve repoya ASLA commit edilmez.
# Boş bırakılırsa varsayılan: ${user.home}/account-hr-data/faturalar
# Uygulama başlangıçta kök + waiting/ + trash/ alt dizinlerini oluşturur (boş başlar).
# Drive aynası `expenses/faturalar` ile KARIŞTIRILMAMALI — o dizine bu servis dokunmaz.
# Staging/prod'da kalıcı bir volume yolu verin (ör. /var/lib/account-hr/faturalar).
STORAGE_ROOT=

# --- JWT auth (E1-03) ---
# Secret HS256 imzalama için en az 32 byte olmalı; PROD'da MUTLAKA değiştirin.
APP_JWT_SECRET=dev-only-change-me-jwt-secret-min-32-bytes-long-0123456789
# Access token ömrü (saniye) — varsayılan 15 dk.
APP_JWT_ACCESS_TTL=900
# Refresh token ömrü (saniye) — varsayılan 7 gün.
APP_JWT_REFRESH_TTL=604800

# İlk admin (V3 migrasyonu ile seed edilir):
#   email: admin@e-commint.com  parola: changeme123  → ilk girişten sonra değiştirin.
